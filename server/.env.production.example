# Server Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For local development: use local MongoDB
# MONGO_URI=mongodb://localhost:27017/focusflow

# For production: MongoDB Atlas cloud
# Get this from MongoDB Atlas -> Connect -> Drivers -> Connection String
MONGO_URI=mongodb+srv://focusflow_user:<PASSWORD>@focusflow-cluster.xxxxx.mongodb.net/focusflow?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION
# ============================================
# Generate with: openssl rand 32 -base64
# MUST be different for each environment (dev, staging, production)
# Change this in production!
JWT_SECRET=your_super_secret_jwt_key_change_in_production_123456789

# ============================================
# SERVER CONFIGURATION
# ============================================
# Development: development
# Production: production
NODE_ENV=development

# Port to run the Express server on
PORT=5000

# ============================================
# SERVICES URLS
# ============================================
# ML Service URL - where Python Flask app is running
# Local: http://localhost:5001
# Production: https://focusflow-ml.onrender.com
ML_SERVICE_URL=http://localhost:5001

# Frontend URL - for CORS configuration
# Local: http://localhost:5173 or http://localhost:3000
# Production: https://focusflow-web.onrender.com or your custom domain
CLIENT_URL=http://localhost:5173

# ============================================
# RENDER.COM DEPLOYMENT ONLY
# ============================================
# Set these when deploying on Render:
# NODE_ENV=production
# MONGO_URI=<from MongoDB Atlas>
# JWT_SECRET=<strong random string>
# ML_SERVICE_URL=<your Render ML service URL>
# CLIENT_URL=<your Render frontend URL>
